{
	"name": "vue-formify",
	"private": false,
	"version": "2.1.3",
	"type": "module",
	"workspaces": [
		"packages/*",
		"docs/*"
	],
	"description": "Build powerful, type-safe forms in Vue.",
	"sideEffects": false,
	"keywords": [
		"vue",
		"vue3",
		"form",
		"forms",
		"formify",
		"vue-formify"
	],
	"files": [
		"dist",
		"dist/vue-formify.js",
		"dist/vue-formify.mjs",
		"dist/vue-formify.d.ts"
	],
	"main": "./dist/vue-formify.umd.js",
	"module": "./dist/vue-formify.es.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/vue-formify.es.js",
			"require": "./dist/vue-formify.umd.js"
		}
	},
	"scripts": {
		"start": "vue-tsc && vite build --watch",
		"build": "bun run vitest && bun run oxl:lint && vue-tsc && vite build",
		"build:npm": "vite build",
		"build:local": "vite build",
		"dev": "vite",
		"oxl:lint": "oxlint ./src",
		"lint:tsc": "vue-tsc --noEmit -p tsconfig.json ",
		"vitest": "vitest run",
		"vitest:hot": "vitest",
		"test": "npm run vitest"
	},
	"peerDependencies": {
		"vue": "^3"
	},
	"devDependencies": {
		"@primevue/themes": "^4.0",
		"@types/node": "^25.2",
		"@vitejs/plugin-vue": "^6.0",
		"@vue/test-utils": "^2.4",
		"arktype": "^2.1",
		"ajv": "^8.18",
		"happy-dom": "^20.6.1",
		"oxlint": "^1.48",
		"path": "^0.12",
		"primevue": "^4.0",
		"rollup-plugin-typescript2": "^0.36",
		"typescript": "^5.8",
		"unocss": "^66.1",
		"valibot": "^1.0",
		"vite": "8.0",
		"vite-plugin-dts": "^4.5",
		"vite-plugin-vue-devtools": "^8.0",
		"vitest": "^4.0",
		"vue": "^3.5",
		"vue-tsc": "^3.2",
		"zod": "^4.3"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mateenagy/vue-formify.git"
	},
	"bugs": {
		"url": "https://github.com/mateenagy/vue-formify/issues"
	},
	"homepage": "https://vue-formify.matenagy.me/",
	"author": "Máté Nagy"
}
